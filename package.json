{
  "name": "shelvy-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend/env-monitor-backend"
  ],
  "scripts": {
    "start:frontend": "npm --workspace frontend start",
    "start:backend": "npm --workspace backend/env-monitor-backend run dev",
    "install:frontend": "npm --workspace frontend install",
    "install:backend": "npm --workspace backend/env-monitor-backend install"
  }
}
